@article{Yang2014a,
abstract = {AbstractThe sensitivities of the Brewer-Dobson Circulation (BDC) to different distributions of tropical SST heating are investigated in an idealized aqua-planet model. It is found that an increase in tropical SSTs generally leads to an acceleration of tropical upwelling and an associated reduction in the Age of Air (AOA) in the polar stratosphere, and that the AOA near the subtropical tropopause is correlated with local isentropic mixing of tropospheric air with stratospheric air.The zonal distribution of SST perturbations has a major impact on the vertical and meridional structure of the BDC as compared with other SST characteristics. Zonally localized SST heatings tend to generate a shallow acceleration of the stratospheric residual circulation, enhanced isentropic mixing associated with a weakened stratospheric jet, and a reduction in AOA mostly within the polar vortex. Contrarily, SST heatings with a zonally symmetric structure tend to produce a deep strengthening of the stratospheric residual circula...},
author = {Yang, Huang and Chen, Gang and Domeisen, Daniela I.V. V.},
doi = {10.1175/JAS-D-13-0276.1},
file = {:C$\backslash$:/Users/gc352/Box Sync/Research/papers/Yang, Chen, Domeisen{\_}2014.pdf:pdf},
issn = {0022-4928},
journal = {Journal of the Atmospheric Sciences},
language = {EN},
month = {jul},
number = {7},
pages = {2674--2694},
title = {{Sensitivities of the Lower-Stratospheric Transport and Mixing to Tropical SST Heating}},
url = {http://journals.ametsoc.org/doi/abs/10.1175/JAS-D-13-0276.1},
volume = {71},
year = {2014}
}
