issn = {0894-8755},
journal = {Journal of Climate},
month = {aug},
number = {15},
pages = {5675--5697},
title = {{Wave Events: Climatology, Trends, and Relationship to Northern Hemisphere Winter Blocking and Weather Extremes}},
url = {http://journals.ametsoc.org/doi/10.1175/JCLI-D-16-0692.1},
volume = {30},
year = {2017}
}
